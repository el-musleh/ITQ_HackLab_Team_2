{
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "disableYoloMode": false,
    "environmentVariableRedaction": {
      "enabled": true
    },
    "autoAddToPolicyByDefault": true,
    "enablePermanentToolApproval": true
  },
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "name": "turn-alert",
            "type": "command",
            "command": "notify-send 'Antigravity CLI' 'Response received' && paplay /usr/share/sounds/freedesktop/stereo/message.oga"
          }
        ]
      }
    ]
  },
  "skills": {
    "disabled": [
      "ui-design-system",
      "ux-researcher-designer",
      "vue-expert",
      "vue-expert-js",
      "websocket-engineer",
      "x-twitter-growth"
    ]
  },
  "general": {
    "defaultApprovalMode": "default",
    "notificationMethod": "bell",
    "plan": {
      "directory": ""
    },
    "sessionRetention": {
      "maxAge": "30d"
    },
    "enableNotifications": true
  },
  "experimental": {
    "autoMemory": true,
    "generalistProfile": true,
    "contextManagement": true,
    "worktrees": true,
    "modelSteering": true,
    "directWebFetch": true,
    "gemmaModelRouter": {
      "enabled": true,
      "autoStartServer": true
    },
    "memoryV2": true,
    "voice": {
      "whisperModel": "ggml-base.en.bin",
      "activationMode": "push-to-talk"
    },
    "voiceMode": true
  },
  "tools": {
    "sandboxNetworkAccess": true
  },
  "ui": {
    "terminalBuffer": true,
    "useBackgroundColor": true,
    "showModelInfoInChat": true,
    "showCitations": true,
    "showMemoryUsage": true,
    "footer": {
      "hideModelInfo": false,
      "hideContextPercentage": false
    },
    "hideWindowTitle": false,
    "showStatusInTitle": false,
    "theme": "Default"
  },
  "ide": {
    "enabled": true
  },
  "context": {
    "fileFiltering": {
      "respectGitIgnore": false,
      "respectGeminiIgnore": false
    }
  }
}
